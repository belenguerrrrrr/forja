# ============================================
# FORJA — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# ============================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FORJA

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...

# Claude API (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxx...

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx...
STRIPE_SECRET_KEY=sk_test_xxx...
STRIPE_WEBHOOK_SECRET=whsec_xxx...

# IDs de precios en Stripe (crear en Stripe Dashboard)
STRIPE_PRICE_PRO_MONTHLY=price_xxx...    # 9,99€/mes
STRIPE_PRICE_PRO_ANNUAL=price_xxx...     # 59€/año
STRIPE_PRICE_LIFETIME=price_xxx...       # 149€ pago único

# Resend (emails transaccionales)
RESEND_API_KEY=re_xxx...
RESEND_FROM_EMAIL=noreply@forjafit.es

# Cron jobs (para informes semanales automáticos)
CRON_SECRET=un_secreto_largo_y_aleatorio_aqui
